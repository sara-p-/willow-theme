{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Outline White",
  "slug": "outline-white",
  "blockTypes": ["core/button"],
  "styles": {
    "color": {
      "background": "transparent",
      "text": "var:preset|color|white"
    },
    "border": {
      "radius": "30px",
      "style": "solid",
      "width": "1px",
      "color": "var:preset|color|white"
    },
    "spacing": {
      "padding": {
        "bottom": "4px",
        "left": "2rem",
        "right": "2rem",
        "top": "4px"
      }
    }
  }
}
