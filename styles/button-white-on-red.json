{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "White on Red",
  "slug": "white-on-red",
  "blockTypes": ["core/button"],
  "styles": {
    "color": {
      "background": "var:preset|color|red",
      "text": "var:preset|color|white"
    },
    ":hover": {
      "color": {
        "background": "var:preset|color|white",
        "text": "var:preset|color|red"
      }
    },
    "border": {
      "radius": "30px",
      "style": "none",
      "width": "0px"
    },
    "spacing": {
      "padding": {
        "bottom": "4px",
        "left": "2rem",
        "right": "2rem",
        "top": "4px"
      }
    }
  }
}
