{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "blocks": {
      "core/heading": {
        "typography": {
          "fontFamilies": []
        }
      }
    },
    "color": {
      "background": true,
      "custom": false,
      "customGradient": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "gradients": [
        {
          "color": "#CEDA9D",
          "gradient": "linear-gradient(180deg, #CEDA9D 0%, #FFF 100%)",
          "name": "Green to White Gradient",
          "slug": "green-to-white"
        },
        {
          "color": "#FFFFFF",
          "gradient": "linear-gradient(0deg,rgb(255,255,255) 0%,rgb(240,223,206) 100%)",
          "name": "White to Pink",
          "slug": "white-to-pink"
        },
        {
          "color": "#FFFFFF",
          "gradient": "linear-gradient(0deg, #F0DFCE 0%, #FFF 100%)",
          "name": "Pink to White",
          "slug": "pink-to-white"
        }
      ],
      "palette": [
        {
          "color": "#F1977C",
          "name": "Pink",
          "slug": "pink"
        },
        {
          "color": "#231F20",
          "name": "Black",
          "slug": "black"
        },
        {
          "color": "#67201E",
          "name": "Red",
          "slug": "red"
        },
        {
          "color": "#3A4740",
          "name": "Dark Green",
          "slug": "dark-green"
        },
        {
          "color": "#CEDA9D",
          "name": "Light Green",
          "slug": "light-green"
        },
        {
          "color": "#F0DFCE",
          "name": "Light Pink",
          "slug": "light-pink"
        },
        {
          "color": "#FEFFFB",
          "name": "Off White",
          "slug": "off-white"
        },
        {
          "color": "#FFFFFF",
          "name": "White",
          "slug": "white"
        }
      ],
      "text": true
    },
    "layout": {
      "contentSize": "600px",
      "wideSize": "1190px"
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "fluid": true,
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Helvetica, Arial, sans-serif",
          "name": "Helvetica",
          "slug": "helvetica"
        },
        {
          "fontFace": [
            {
              "fontFamily": "\"AR One Sans\"",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/ar-one-sans/ar-one-sans-700-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"AR One Sans\"",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/ar-one-sans/ar-one-sans-600-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"AR One Sans\"",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [
                "file:./assets/fonts/ar-one-sans/ar-one-sans-500-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"AR One Sans\"",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/ar-one-sans/ar-one-sans-400-normal.woff2"
              ]
            }
          ],
          "fontFamily": "\"AR One Sans\", sans-serif",
          "name": "AR One Sans",
          "slug": "ar-one-sans"
        },
        {
          "fontFace": [
            {
              "fontFamily": "\"Crimson Text\"",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/crimson-text/crimson-text-400-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Crimson Text\"",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/crimson-text/crimson-text-600-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Crimson Text\"",
              "fontStyle": "italic",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/crimson-text/crimson-text-600-italic.woff2"
              ]
            }
          ],
          "fontFamily": "\"Crimson Text\", serif",
          "name": "Crimson Text",
          "slug": "crimson-text"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--red)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--ar-one-sans)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--red)"
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--helvetica)",
      "fontSize": "16px",
      "letterSpacing": "-0.32px",
      "lineHeight": "1.75"
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    }
  ]
}
