{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"blocks": {
			"core/heading": {
				"typography": {
					"fontFamilies": []
				}
			}
		},
		"color": {
			"background": true,
			"custom": false,
			"customGradient": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"gradients": [
				{
					"color": "#CEDA9D",
					"gradient": "linear-gradient(180deg, #CEDA9D 0%, #FFF 100%)",
					"name": "Green to White Gradient",
					"slug": "green-to-white"
				},
				{
					"color": "#FFFFFF",
					"gradient": "linear-gradient(0deg,rgb(255,255,255) 0%,rgb(240,223,206) 100%)",
					"name": "White to Pink",
					"slug": "white-to-pink"
				},
				{
					"color": "#FFFFFF",
					"gradient": "linear-gradient(0deg, #F0DFCE 0%, #FFF 100%)",
					"name": "Pink to White",
					"slug": "pink-to-white"
				}
			],
			"palette": [
				{
					"color": "#F1977C",
					"name": "Pink",
					"slug": "pink"
				},
				{
					"color": "#231F20",
					"name": "Black",
					"slug": "black"
				},
				{
					"color": "#67201E",
					"name": "Red",
					"slug": "red"
				},
				{
					"color": "#3A4740",
					"name": "Dark Green",
					"slug": "dark-green"
				},
				{
					"color": "#CEDA9D",
					"name": "Light Green",
					"slug": "light-green"
				},
				{
					"color": "#F0DFCE",
					"name": "Light Pink",
					"slug": "light-pink"
				},
				{
					"color": "#FEFFFB",
					"name": "Off White",
					"slug": "off-white"
				},
				{
					"color": "#FFFFFF",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#FFFDF7",
					"name": "Warm White",
					"slug": "warm-white"
				}
			],
			"text": true
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1190px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Extra Small",
					"size": "clamp(0.75rem, calc(0.659rem + 0.455vw), 1rem)",
					"slug": "16"
				},
				{
					"name": "Small",
					"size": "clamp(1.5rem, calc(1.318rem + 0.909vw), 2rem)",
					"slug": "32"
				},
				{
					"name": "Medium",
					"size": "clamp(2rem, calc(1.636rem + 1.818vw), 3rem)",
					"slug": "48"
				},
				{
					"name": "Large",
					"size": "clamp(2rem, calc(0.833rem + 3.889vw), 3.75rem)",
					"slug": "60"
				},
				{
					"name": "Extra Large",
					"size": "clamp(3.75rem, calc(2.386rem + 6.818vw), 7.5rem)",
					"slug": "120"
				},
				{
					"name": "Extra Extra Large",
					"size": "clamp(7.5rem, calc(6.591rem + 4.545vw), 10rem)",
					"slug": "160"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Helvetica, Arial, sans-serif",
					"name": "Helvetica",
					"slug": "helvetica"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"AR One Sans\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/ar-one-sans/ar-one-sans-700-normal.woff2"
							]
						},
						{
							"fontFamily": "\"AR One Sans\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/ar-one-sans/ar-one-sans-600-normal.woff2"
							]
						},
						{
							"fontFamily": "\"AR One Sans\"",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/ar-one-sans/ar-one-sans-500-normal.woff2"
							]
						},
						{
							"fontFamily": "\"AR One Sans\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/ar-one-sans/ar-one-sans-400-normal.woff2"
							]
						}
					],
					"fontFamily": "\"AR One Sans\", sans-serif",
					"name": "AR One Sans",
					"slug": "ar-one-sans"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Crimson Text\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/crimson-text/crimson-text-400-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Crimson Text\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/crimson-text/crimson-text-600-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Crimson Text\"",
							"fontStyle": "italic",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/crimson-text/crimson-text-600-italic.woff2"
							]
						}
					],
					"fontFamily": "\"Crimson Text\", serif",
					"name": "Crimson Text",
					"slug": "crimson-text"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--red)",
			"text": "var(--wp--preset--color--white)"
		},
		"css": ".absolute-bottom {\n  position: absolute;\n  bottom: -20px;\n  left: 0;\n  right: 0;\n}\n\n.absolute-top {\n  position: absolute;\n  top: -20px;\n  left: 0;\n  right: 0;\n}\n\n.relative-position {\n  position: relative;\n}\n\n.pricing-slider .swiper {\n  overflow: visible;\n}\n\n.pricing-slider .cb-button-prev {\n  top: 104%;\n  left: 46.5%;\n  color: #67201e;\n}\n\n.pricing-slider .cb-button-next {\n  top: 104%;\n  right: 46.5%;\n  color: #67201e;\n}\n\n.pricing-slider .cb-pagination .swiper-pagination-bullet {\n  background: #67201e;\n}\n\n.swiper-wrapper {\n  align-items: center;\n}",
		"elements": {
			"button": {
				"border": {
					"color": "var(--wp--preset--color--pink)",
					"radius": "30px",
					"style": "solid",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--pink)",
					"text": "var(--wp--preset--color--red)"
				},
				"spacing": {
					"padding": {
						"bottom": "4px",
						"left": "2rem",
						"right": "2rem",
						"top": "4px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--crimson-text)",
					"fontSize": "18px",
					"fontStyle": "italic",
					"fontWeight": "600"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--crimson-text)",
					"fontSize": "clamp(1.25rem, calc(0.833rem + 1.389vw), 1.88rem)",
					"fontStyle": "italic",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--ar-one-sans)",
					"fontSize": "clamp(2.50rem, calc(0.833rem + 5.556vw), 5.00rem)",
					"fontWeight": "600",
					"letterSpacing": "-3.2px",
					"lineHeight": "1.08"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--ar-one-sans)",
					"fontSize": "clamp(2.19rem, calc(1.960rem + 1.136vw), 2.81rem)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--crimson-text)",
					"fontSize": "clamp(2.19rem, calc(1.960rem + 1.136vw), 2.81rem)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--crimson-text)",
					"fontSize": "clamp(1.25rem, calc(0.833rem + 1.389vw), 1.88rem)",
					"fontStyle": "italic",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--ar-one-sans)",
					"fontSize": "clamp(1.25rem, calc(1.136rem + 0.568vw), 1.56rem)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--ar-one-sans)",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--red)"
				}
			}
		},
		"spacing": {
			"blockGap": "0px",
			"margin": {
				"bottom": "0px",
				"left:": "0px",
				"right": "0px",
				"top": "0px"
			},
			"padding": {
				"bottom": "0px",
				"left": "2rem",
				"left:": "26px",
				"right": "2rem",
				"top": "0px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--helvetica)",
			"fontSize": "16px",
			"letterSpacing": "-0.32px",
			"lineHeight": "1.75"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		}
	]
}